---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import TagsBar from '../../components/TagsBar.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const uniqueTags = [...new Set(allPosts.map((post) => post.data.tags).flat())].filter(Boolean);

  return uniqueTags.map((tag) => {
    // סינון הפוסטים ומיון מהחדש לישן
    const filteredPosts = allPosts
      .filter((post) => post.data.tags?.includes(tag))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
      
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout title={`פוסטים בנושא: ${tag}`}>
  <main dir="rtl" class="container">
    <h1 class="page-title">מחשבות בנושא: {tag}</h1>
    
    <TagsBar activeTag={tag} />

    <ul class="posts-grid">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}/`}>
            <img src={post.data.heroImage} alt="" />
            <h4 class="title">{post.data.title}</h4>
            <p class="date">
              {post.data.pubDate.toLocaleDateString('he-IL', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>