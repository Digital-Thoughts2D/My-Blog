---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import TagsBar from '../../components/TagsBar.astro';

// שליפת כל הפוסטים ומיון מהחדש לישן
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="he" dir="rtl">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
<style>
	main {
		width: 100%;
		max-width: 1140px; 
		margin: 0 auto;
		padding: 2rem 1.5rem;
		box-sizing: border-box;
	}

	section {
		width: 100%;
	}

	/* רשימת הפוסטים - פריסה אופקית שמתפצלת ל-2 טורים */
	ul {
		display: flex;
		flex-wrap: wrap;
		gap: 2.5rem;
		list-style-type: none;
		margin: 2rem 0 0 0;
		padding: 0;
		width: 100%;
	}

	/* כל פוסט תופס בדיוק חצי מהרוחב פחות חצי מהרווח (gap) */
	ul li {
		width: calc(50% - 1.25rem);
		box-sizing: border-box;
	}

	/* ביטול ההגדרה של התבנית המקורית שהפכה את הפוסט הראשון ל-100% */
	ul li:first-child {
		width: calc(50% - 1.25rem) !important;
		margin-bottom: 0 !important;
		text-align: right !important;
	}
	
	ul li:first-child .title {
		font-size: 1.35rem !important;
	}

	ul li a {
		display: flex;
		flex-direction: column;
		text-decoration: none;
	}

	/* מיכל התמונה השומר על פרופורציות קבועות */
	.image-wrapper {
		width: 100%;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		border-radius: 24px;
		margin-bottom: 1.2rem;
		background-color: rgb(var(--gray-light));
	}

	ul li img {
		width: 100% !important;
		height: 100% !important;
		object-fit: cover;
		transition: transform 0.5s ease;
		border-radius: 24px;
	}

	.title {
		margin: 0 0 0.4rem 0;
		color: rgb(var(--black));
		font-size: 1.35rem;
		font-weight: 700;
		line-height: 1.3;
	}

	.date {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.9rem;
	}

	/* אפקטים במעבר עכבר */
	ul li a:hover .title {
		color: var(--accent);
	}

	ul li a:hover img {
		transform: scale(1.03);
	}

	/* מובייל - מעבר לטור אחד מלא */
	@media (max-width: 768px) {
		ul {
			gap: 2rem;
		}
		ul li, ul li:first-child {
			width: 100% !important;
		}
		.title {
			font-size: 1.2rem;
		}
	}
</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
			<h1>המחשבות שלי</h1>
			<TagsBar activeTag={typeof window !== 'undefined' ? new URLSearchParams(window.location.search).get('tag') : undefined} />

<ul>
	{
		posts.map((post) => (
			/* שומרים על ה-data-tags בשביל סקריפט הסינון שכבר בנית */
			<li data-tags={post.data.tags ? post.data.tags.join(',') : ''}>
				<a href={`./${post.id}/`}>
					{post.data.heroImage && (
						<div class="image-wrapper">
							<Image width={720} height={450} src={post.data.heroImage} alt="" />
						</div>
					)}
					<h4 class="title">{post.data.title}</h4>
					<p class="date">
						<FormattedDate date={post.data.pubDate} />
					</p>
				</a>
			</li>
		))
	}
</ul>
			</section>
		</main>
		<Footer />

		{/* קוד ה-JavaScript שמבצע את הסינון הדינמי והצביעה של הכפתורים על המסך */}
		<script>
			function filterPosts() {
				const urlParams = new URLSearchParams(window.location.search);
				const activeTag = urlParams.get('tag');
				
				// 1. סינון הפוסטים ויזואלית
				const postElements = document.querySelectorAll('main ul li');
				postElements.forEach((el) => {
					const tagsAttr = el.getAttribute('data-tags') || '';
					const postTags = tagsAttr.split(',').filter(Boolean);
					
					if (!activeTag || postTags.includes(activeTag)) {
						(el as HTMLElement).style.display = 'block';
					} else {
						(el as HTMLElement).style.display = 'none';
					}
				});

				// 2. עדכון צביעת הכפתורים (Active State)
				const tagButtons = document.querySelectorAll('.tag-button');
				tagButtons.forEach((btn) => {
					const href = btn.getAttribute('href') || '';
					
					if (!activeTag && (href === '.' || href === '/blog/')) {
						btn.classList.add('active');
					} else if (activeTag && href.includes(`tag=${encodeURIComponent(activeTag)}`)) {
						btn.classList.add('active');
					} else {
						btn.classList.remove('active');
					}
				});
			}

			// הפעלת הסינון כשהדף נטען
			filterPosts();
			
			// האזנה לאירועים למקרה שהניווט משתנה ללא רענון מלא (תמיכה ב-Astro View Transitions)
			document.addEventListener('astro:after-swap', filterPosts);
		</script>
	</body>
</html>