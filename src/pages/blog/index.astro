---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import TagsBar from '../../components/TagsBar.astro';

// שליפת כל הפוסטים ומיון מהחדש לישן
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="he" dir="rtl">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				{/* נספק ל-TagsBar את התגית מתוך ה-URL אם היא קיימת כדי שיצבע את הכפתור הנכון */}
				<TagsBar activeTag={typeof window !== 'undefined' ? new URLSearchParams(window.location.search).get('tag') : undefined} />

				<ul>
					{
						posts.map((post) => (
							/* הוספנו מאפיין data-tags שמכיל את התגיות של הפוסט כטקסט */
							<li data-tags={post.data.tags ? post.data.tags.join(',') : ''}>
								<a href={`./${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />

		{/* קוד ה-JavaScript שמבצע את הסינון הדינמי והצביעה של הכפתורים על המסך */}
		<script>
			function filterPosts() {
				const urlParams = new URLSearchParams(window.location.search);
				const activeTag = urlParams.get('tag');
				
				// 1. סינון הפוסטים ויזואלית
				const postElements = document.querySelectorAll('main ul li');
				postElements.forEach((el) => {
					const tagsAttr = el.getAttribute('data-tags') || '';
					const postTags = tagsAttr.split(',').filter(Boolean);
					
					if (!activeTag || postTags.includes(activeTag)) {
						(el as HTMLElement).style.display = 'block';
					} else {
						(el as HTMLElement).style.display = 'none';
					}
				});

				// 2. עדכון צביעת הכפתורים (Active State)
				const tagButtons = document.querySelectorAll('.tag-button');
				tagButtons.forEach((btn) => {
					const href = btn.getAttribute('href') || '';
					
					if (!activeTag && (href === '.' || href === '/blog/')) {
						btn.classList.add('active');
					} else if (activeTag && href.includes(`tag=${encodeURIComponent(activeTag)}`)) {
						btn.classList.add('active');
					} else {
						btn.classList.remove('active');
					}
				});
			}

			// הפעלת הסינון כשהדף נטען
			filterPosts();
			
			// האזנה לאירועים למקרה שהניווט משתנה ללא רענון מלא (תמיכה ב-Astro View Transitions)
			document.addEventListener('astro:after-swap', filterPosts);
		</script>
	</body>
</html>