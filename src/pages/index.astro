---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import FormattedDate from "../components/FormattedDate.astro";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const featuredPosts = (await getCollection("blog"))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 1);
---

<!doctype html>
<html lang="he" dir="rtl">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

		<style>
			main {
				width: 100%;
				max-width: 800px;
				margin: 0 auto;
				padding: 4rem 1.5rem;
				box-sizing: border-box;
			}

			h1 {
				font-size: 2.5rem;
				font-weight: 800;
				color: rgb(var(--black));
				margin-bottom: 2rem;
				letter-spacing: -0.02em;
				text-align: right;
			}

			p {
				font-size: 1.125rem;
				line-height: 1.75;
				color: rgb(var(--gray-dark));
				margin-bottom: 1.75rem;
				text-align: justify;
			}

			.animation-container-wrapper {
				width: 100%;
				display: flex;
				justify-content: center;
				align-items: flex-end;
				margin: 0 auto;
				height: 150px;
				overflow: hidden;
			}

			#lottie-animation {
				width: 400px;
				height: 400px;
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.featured-section {
				border-top: 1px solid rgba(var(--black), 0.08);
				padding-top: 3rem;
			}

			.section-title {
				font-size: 1.75rem;
				font-weight: 800;
				color: rgb(var(--black));
				margin-bottom: 2rem;
			}

			.posts-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 2.5rem;
				list-style-type: none;
				padding: 0;
				margin: 0;
			}

			.post-card a {
				display: flex;
				flex-direction: column;
				text-decoration: none;
			}

			.image-wrapper {
				width: 100%; /* שינינו ל-100% כדי שיסתדר עם הגריד */
				height: 190px; /* הוספת px כדי שהדפדפן יזהה את הגובה במחשב */
				overflow: hidden;
				border-radius: 20px;
				background-color: rgb(var(--gray-light));
				margin-top: 0.8rem; /* מרווח קטן בין התיאור לתמונה */
			}

			.post-card img {
				width: 100%;
				height: 100%;
				object-fit: cover;

				/* transition: transform 0.5s ease; */
			}
			.post-title {
				margin: 0.5rem 0 0.3rem 0;
				color: rgb(var(--black));
				font-size: 1.25rem;
				font-weight: 700;
				line-height: 1.3;
				transition: color 0.3s ease;
			}

			.post-description {
				margin: 0 0 0.3rem 0;
				font-size: 0.95rem;
				line-height: 1.4;
				color: rgb(var(--gray-dark));
				font-weight: 400;
			}

			.post-date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.85rem;
			}

			.post-card a:hover .post-title {
				color: var(--accent);
				text-decoration: underline;
			}

			.post-card a:hover img {
				transform: scale(1);
			}

			@media (max-width: 768px) {
				main {
					/* משאיר מרווח צידי נעים ואסתטי של 1.5rem מהצדדים של הסמארטפון */
					padding: 2.5rem 1.5rem;
				}
				h1 {
					/* מגדיל את הכותרת הראשית בנייד שתהיה נוכחת ומרשימה */
					font-size: 1.85rem;
				}
				p {
					/* התאמה עדינה של הטקסט הרגיל לנייד */
					font-size: 1.05rem;
					line-height: 1.65;
				}
				.posts-grid {
					grid-template-columns: 1fr;
					gap: 1.5rem;
				}

				/* התאמת גודל התמונה שתתפרס יפה בנייד */
				.image-wrapper {
					width: 100%;
					height: 160px;
				}

				.animation-container-wrapper {
					height: 160px;
				}
				#lottie-animation {
					width: 260px;
					height: 260px;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<h1>שלום לכל המבקרים</h1>

			<p>
				זה הבלוג שלי, הבלוג של ליזה. אני מתכוונת לשתף כאן את המחשבות,
				האמונות והתובנות שלי.
			</p>

			<p>
				הקמתי את הבלוג הזה כי אני לא נוהגת לשתף אנשים במה שקורה איתי או
				בדעות שלי.<br />
				תמיד הייתי יותר "הטיפוס המקשיב". והאמת, זאת ברכה להיות כזאת וזה לא
				משהו שהייתי רוצה לשנות בעצמי.<br />
				אני לא מפחדת להביע את עצמי בפני אנשים או בפני האינטרנט, אבל אתם יודעים,
				כל פלטפורמה והנושא שלה. באתר שלי יש לי את החופש לדבר ולשתף את מה שאני
				רוצה מתי שאני רוצה.
			</p>

			<p>
				בלוג זה הפתרון המושלם לאנשים כמוני. אנשים שרוצים לחלוק את הידע
				והמחשבות שלהם עם העולם אבל לא תמיד מוצאים דרך להתבטא או את
				הטיימניג המתאים לכך. בגלל שעשיתי תואר במדעי המחשב אני לא מפחדת
				להתעסק בעניינים הטכניים כמו הקמת פלטפורמה משלי ותחזוקת אתר, משהו
				שלדעתי המון אנשים נמנעים ממנו בגלל הפחד להתעסק עם העניינים האלה.<br
				/>
				ביחד עם החוש היצירתי שלי אני מקבלת הנאה מהקמת אתר, העיצוב, התכנון
				והכתיבה.<br />
				לפחות משהו טוב יוצא לי מהתואר הזה.
			</p>

			<p>
				אז קוראים לי ליזה, בת 25 נכון לכתיבת שורות אלו. מתמודדת עם
				האתגרים הקלאסיים של ג'ן זי בעולמנו ובמדינת ישראל בפרט. אני הולכת
				לשתף בהתמודדות האישית שלי עם העולם הזה, שלפעמים מרגיש לי שהוא לא
				בנוי בשבילי. אני אפרוס כאן את המחשבות האמיתיות שלי על הדף, בלי
				שימוש בכלי בינה מלאכותית לכתיבת הבלוג. הטקסטים שתראו על המסך הם
				האני שלי, הכי אותנטיים. את השימוש הטכני שלי בכלי בינה מלאכותית
				במסגרת הבלוג הזה אני מפרטת בלשונית
				<a href={import.meta.env.BASE_URL + "about/"}>אודות</a> כאן באתר.
			</p>

			<div class="animation-container-wrapper">
				<div id="lottie-animation"></div>
			</div>

			<div class="featured-section">
				<h2 class="section-title">קריאה נבחרת</h2>

				<ul class="posts-grid">
					{
						featuredPosts.map((post) => {
							const displayImage =
								post.data.featuredImage || post.data.heroImage;

							return (
								<li class="post-card">
									<a
										href={`${import.meta.env.BASE_URL}blog/${post.id}/`}
									>
										<h3 class="post-title">
											{post.data.title}
										</h3>
										<p class="post-description">
											{post.data.description}
										</p>
										{displayImage && (
											<div class="image-wrapper">
												<Image
													width={720}
													height={450}
													src={displayImage}
													alt=""
												/>
											</div>
										)}
										{/* <p class="post-date">
																					<FormattedDate
																																	date={post.data.pubDate}
																																												/>
																																																						</p> */}
									</a>
								</li>
							);
						})
					}
				</ul>
			</div>
		</main>

		<Footer />

		<script
			type="module"
			define:vars={{ baseUrl: import.meta.env.BASE_URL }}
		>
			import lottie from "https://cdn.skypack.dev/lottie-web";

			function initAnimation() {
				const container = document.getElementById("lottie-animation");

				if (container) {
					container.innerHTML = "";

					lottie.loadAnimation({
						container: container,
						renderer: "svg",
						loop: true,
						autoplay: true,
						path: `${baseUrl}animations/cat.json`,
						rendererSettings: {
							preserveAspectRatio: "xMidYMid slice",
							hideOnTransparentBlur: true,
						},
					});
				}
			}

			initAnimation();
			document.addEventListener("astro:after-swap", initAnimation);
		</script>
	</body>
</html>
