---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = Omit<CollectionEntry<'blog'>['data'], 'pubDate' | 'heroImage'> & {
	pubDate?: Date;
	heroImage?: any;
};

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="he" dir="rtl">
	<head>
		<BaseHead title={title} description={description} />
<style>
			/* הבטחת התנהגות גלילה נכונה בשביל ה-Header הסטיקי */
			:global(html), :global(body) {
				scroll-behavior: smooth;
				overflow-x: hidden; /* מונע גלישה אופקית מציקה במובייל */
			}

			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;
				padding: 0 1em; 
				box-sizing: border-box;
			}
			.hero-image {
				width: 100%;
				margin: 0 auto 2em auto; 
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				width: 100%;        
				max-width: 100%;    
				height: auto;       
			}
			.prose {
				width: 720px;
				max-width: 100%; /* שינוי ל-100% כדי למנוע כיווץ יתר במובייל */
				margin: auto;
				padding: 1em 0; /* הורדת הפדינג הצידי כדי לנצל את המסך במובייל */
				color: rgb(var(--gray-dark));
				box-sizing: border-box;
			}
			
			/* 🔥 התאמת תוכן ה-Markdown (ה-slot) למובייל */
			.prose :global(img) {
				max-width: 100%;
				height: auto;
				border-radius: 8px;
				margin: 1.5rem auto;
				display: block;
			}

			.prose :global(ul), .prose :global(ol) {
				padding-right: 1.5rem; /* מבטיח שהנקודות/מספרים בעברית לא יחתכו מהמסך */
				padding-left: 0;
				margin-bottom: 1.5rem;
			}

			.prose :global(p) {
				margin-bottom: 1.25rem;
				line-height: 1.8;
				font-size: 1.1rem;
				text-align: justify;
			}

			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1.3; /* הגדלת גובה השורה למקרה שהכותרת ארוכה ויורדת שורה */
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 2rem;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}

			/* התאמות ספציפיות למסכים קטנים מאוד */
			@media (max-width: 720px) {
				.prose {
					padding: 0.5rem 0;
				}
				.title h1 {
					font-size: 1.6rem; /* הקטנת הכותרת הראשית בנייד כדי שלא תיחתך */
				}
				.prose :global(p) {
					font-size: 1.05rem; /* פונט קצת יותר קריא לנייד */
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							{pubDate && <FormattedDate date={pubDate} />} 
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot /> 
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>